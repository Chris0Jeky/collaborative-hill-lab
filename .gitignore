# Secrets — never commit
.env
.env.*

# Claude Code local / machine-specific (the deny floor stays in committed settings.json)
.claude/settings.local.json
.claude/local/
.claude/worktrees/
.claude/scheduled_tasks.lock

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
*.egg-info/

# Generated run artifacts (transparent local outputs; committed only via studies' sealed examples)
artifacts/*
!artifacts/.gitkeep

# Node (if a web/UI surface is added later)
node_modules/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
